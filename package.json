{
  "name": "@animalabs/mcpl-editor",
  "version": "0.1.1",
  "description": "Hosted collaborative Markdown editor and MCPL server",
  "type": "module",
  "main": "./dist/src/index.js",
  "bin": {
    "mcpl-editor": "dist/src/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "build": "tsc && npm --prefix ui install && npm --prefix ui run build && mkdir -p dist/ui && cp -R ui/dist dist/ui/",
    "typecheck": "tsc --noEmit",
    "dev": "node --import tsx src/index.ts",
    "dev:ui": "cd ui && npm run dev"
  },
  "dependencies": {
    "@codemirror/collab": "^6.1.1",
    "@codemirror/state": "^6.5.4",
    "@animalabs/mcpl-core": "^0.2.1",
    "@animalabs/chronicle": "^0.2.6",
    "express": "^4.18.2",
    "tsx": "^4.7.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.9",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anima-research/mcpl-editor.git"
  },
  "homepage": "https://github.com/anima-research/mcpl-editor#readme",
  "bugs": {
    "url": "https://github.com/anima-research/mcpl-editor/issues"
  }
}
